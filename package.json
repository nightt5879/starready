{
  "name": "starready",
  "version": "0.3.0",
  "description": "Audit any GitHub repository for launch-readiness, trust signals, and star-worthy polish.",
  "type": "module",
  "author": "nightt5879",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nightt5879/starready.git"
  },
  "bugs": {
    "url": "https://github.com/nightt5879/starready/issues"
  },
  "homepage": "https://github.com/nightt5879/starready#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "starready": "bin/starready.js"
  },
  "files": [
    "bin/",
    "src/",
    "docs/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/starready.js .",
    "test": "node --test",
    "check": "npm test && node bin/starready.js . --summary --fail-below 80",
    "release:check": "npm run check && npm publish --dry-run",
    "prepublishOnly": "npm run check",
    "audit:self": "node bin/starready.js . --markdown STARREADY_REPORT.md --fail-below 80"
  },
  "keywords": [
    "github",
    "stars",
    "open-source",
    "readme",
    "cli",
    "audit",
    "launch",
    "developer-tools"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.18"
  }
}
